<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Privacy Guardian Control Panel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
</head>
<body>
  <div class="bg-glow" aria-hidden="true"></div>
  <header class="hero">
    <p class="kicker">Privacy Guardian</p>
    <h1>Router Command Center</h1>
    <p class="subtitle">Wi-Fi setup, OTA updates, security settings, and deep device management with category-aware detection.</p>
  </header>

  <main class="layout">
    <section class="panel dashboard">
      <div class="panel-head">
        <h2>Dashboard</h2>
        <button id="refreshData" class="btn btn-small">Refresh Data</button>
      </div>

      <div class="cards" id="statusCards"></div>

      <div class="dash-grid">
        <article class="mini-panel">
          <h3>Network Map</h3>
          <div id="networkMap" class="network-map"></div>
        </article>
        <article class="mini-panel">
          <h3>Security Status</h3>
          <ul class="security-list" id="securityStatus"></ul>
        </article>
      </div>
    </section>

    <section class="panel">
      <h2>Wi-Fi Setup (Generic WPA Router Steps)</h2>
      <ol class="steps" id="wifiSteps"></ol>
    </section>

    <section class="panel two-col">
      <article>
        <h2>Firmware Update (OTA)</h2>
        <p>Use the OTA flow to update packages and restart networking safely.</p>
        <button id="firmwareUpdate" class="btn">Run OTA Update</button>
        <pre class="command" id="firmwareCommand"></pre>
      </article>

      <article>
        <h2>Restart and Toggle</h2>
        <div class="button-row">
          <button class="btn" data-action="restart-services">Restart Core Services</button>
          <button class="btn" data-action="toggle-firewall">Toggle Firewall</button>
          <button class="btn" data-action="toggle-wifi">Toggle Wi-Fi AP</button>
          <button class="btn" data-action="toggle-dns">Toggle DNS Filter</button>
        </div>
        <pre class="command" id="toggleCommand"></pre>
      </article>
    </section>

    <section class="panel two-col">
      <article>
        <h2>Settings</h2>
        <label for="encryption">Wi-Fi Encryption</label>
        <select id="encryption">
          <option value="WPA2">WPA2</option>
          <option value="WPA3">WPA3</option>
          <option value="WPA2/WPA3 Mixed">WPA2/WPA3 Mixed</option>
        </select>

        <label for="firewallMode">Firewall Profile</label>
        <select id="firewallMode">
          <option value="strict">Strict (recommended)</option>
          <option value="balanced">Balanced</option>
          <option value="custom">Custom</option>
        </select>

        <button id="saveSettings" class="btn">Generate Settings Command</button>
        <pre class="command" id="settingsCommand"></pre>
      </article>

      <article>
        <h2>Admin Credentials</h2>
        <label for="adminUser">New Admin Username</label>
        <input id="adminUser" placeholder="routeradmin">

        <label for="adminPass">New Admin Password</label>
        <input id="adminPass" type="password" placeholder="Strong passphrase">

        <button id="updateCreds" class="btn">Generate Credentials Command</button>
        <pre class="command" id="credsCommand"></pre>
      </article>
    </section>

    <section class="panel">
      <div class="panel-head">
        <h2>Device Management (Detection Focus)</h2>
      </div>
      <p class="subtitle small">Devices are auto-categorized by usage and type: IoT (TV/fridge), Personal (laptop/phone), and Public (home servers/common computers or any SSH-reachable host).</p>
      <div class="chips" id="categoryTotals"></div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>IP</th>
              <th>Hostname</th>
              <th>Category</th>
              <th>Type Hint</th>
              <th>SSH Reachable</th>
              <th>Active Flows</th>
              <th>Estimated Bytes</th>
            </tr>
          </thead>
          <tbody id="deviceRows"></tbody>
        </table>
      </div>
    </section>

    <section class="panel muted">
      <h2>Guest Network</h2>
      <p>Intentionally omitted in this build. Your current flow does not require guest network management.</p>
    </section>
  </main>

  <!-- API Configuration -->
  <script src="js/config.js"></script>
  <!-- Dashboard Application -->
  <script src="app.js"></script>
</body>
</html>
