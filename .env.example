# .env.example
# Privacy Guardian Docker Environment Configuration
# Copy this file to .env and modify values as needed

# ─── Network Configuration ──────────────────────────────────────────────────

# Router management IP (device that can SSH + access AdGuard UI)
MGMT_IP=192.168.4.2

# WAN interface (internet-facing, plugged into existing router/modem)
WAN_IF=eth0

# LAN interface (internal, clients connect here)
LAN_IF=wlan0

# LAN network (DHCP range will be derived from this)
LAN_NET=192.168.4.0/24
LAN_IP=192.168.4.1

# ─── WiFi Configuration ─────────────────────────────────────────────────────

# Wi-Fi SSID (network name)
WIFI_SSID=PrivacyGuardian

# Wi-Fi password (minimum 8 characters, WPA2-only)
WIFI_PASS=CHANGE_THIS_PASSWORD_NOW

# Wi-Fi country code (US, GB, DE, IN, etc.)
WIFI_COUNTRY=US

# Wi-Fi channel (1, 6, 11 for 2.4GHz to avoid interference)
WIFI_CHANNEL=6

# ─── AdGuard Home Configuration ──────────────────────────────────────────────

# AdGuard Home admin interface port
ADGUARD_PORT=3000

# AdGuard Home upstream DNS (DoH/DoT recommended)
# Examples:
#   tls://dns.quad9.net (Quad9 - no logging)
#   https://dns.quad9.net/dns-query (Quad9 DoH)
#   tls://dns.mullvad.net (Mullvad - strict no-log)
ADGUARD_UPSTREAM=tls://dns.quad9.net

# ─── Container Configuration ────────────────────────────────────────────────

# Enable hostapd WiFi access point (yes/no)
ENABLE_HOSTAPD=yes

# Container restart policy (no, always, unless-stopped, on-failure)
RESTART_POLICY=unless-stopped

# Timezone (used by AdGuard Home)
TZ=UTC

# ─── Logging Configuration ──────────────────────────────────────────────────

# Enable firewall packet logging (yes/no)
ENABLE_FW_LOGGING=yes

# Enable DHCP logging (yes/no)
ENABLE_DHCP_LOGGING=yes
